# Copy this file to .env and fill in your values

# Server
PORT=5000

# JWT Secret — change this to a long random string in production
JWT_SECRET=roopshield_super_secret_jwt_key_change_me

# Email (for Forgot Password)
# Use Gmail with an App Password (not your real password)
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=RoopShield Portal <your_email@gmail.com>

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:5173
